---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';
import { useTranslation } from '../../../utils/i18n';
import { marked } from 'marked';

export async function getStaticPaths() {
  const cities = await getCollection('cities');
  return cities.flatMap((city) => [
    { params: { lang: 'zh', slug: city.id } },
    { params: { lang: 'en', slug: city.id } }
  ]);
}

const { lang, slug } = Astro.params;
const locale = lang === 'en' ? 'en' : 'zh';
const t = useTranslation(locale);

const city = await getEntry('cities', slug as string);
if (!city) return Astro.redirect('/404');

const { name, nameEn, country, countryEn, population, populationEn, language, languageEn, currency, currencyEn, timezone, bestSeason, bestSeasonEn, image } = city.data;

console.log('=== DEBUG INFO ===');
console.log('locale:', locale);
console.log('population:', population);
console.log('populationEn:', populationEn);
console.log('language:', language);
console.log('languageEn:', languageEn);

const displayName = locale === 'en' ? nameEn : name;
const displayCountry = locale === 'en' ? (countryEn || country) : country;
const displayPopulation = locale === 'en' ? (populationEn || population) : population;
const displayLanguage = locale === 'en' ? (languageEn || language) : language;
const displayCurrency = locale === 'en' ? (currencyEn || currency) : currency;
const displayBestSeason = locale === 'en' ? (bestSeasonEn || bestSeason) : bestSeason;
// 图片需要手动添加 BASE_URL
const imagePath = import.meta.env.BASE_URL.replace(/\/$/, '') + image;

console.log('displayPopulation:', displayPopulation);
console.log('displayLanguage:', displayLanguage);

const rawBody = city.body || '';
const enMatch = rawBody.match(/<!-- EN_START -->([\s\S]*?)<!-- EN_END -->/);
const zhMatch = rawBody.match(/<!-- ZH_START -->([\s\S]*?)<!-- ZH_END -->/);
const enMarkdown = enMatch ? enMatch[1].trim() : '';
const zhMarkdown = zhMatch ? zhMatch[1].trim() : '';
const contentHtml = locale === 'en' && enMarkdown ? marked(enMarkdown) : zhMarkdown ? marked(zhMarkdown) : '';
---

<BaseLayout title={`${displayName} - CityGuide`} locale={locale}>
  <article id="city-detail-container" style="max-width: 1400px; margin: 0 auto; padding: 60px 40px;">
    <div style="margin-bottom: 32px;">
      <h1 style="font-size: 3rem; font-weight: 700; margin-bottom: 8px;" class="text-gray-900 dark:text-white">{displayName}</h1>
      <p style="font-size: 1.5rem; color: #6b7280;">{locale === 'en' ? name : nameEn}</p>
      <p style="color: #9ca3af; margin-top: 8px;">{displayCountry}</p>
    </div>

    <div style="aspect-ratio: 16/9; margin-bottom: 32px; border-radius: 12px; overflow: hidden;">
      <img src={imagePath} alt={displayName} style="width: 100%; height: 100%; object-fit: cover;" />
    </div>

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 32px;">
      <div class="prose max-w-none dark:prose-invert">
        <div set:html={contentHtml} />
      </div>

      <aside style="background: #f9fafb; padding: 24px; border-radius: 12px; height: fit-content;" class="dark:bg-gray-800">
        <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 16px;" class="text-gray-900 dark:text-white">📍 {t.city.info}</h3>
        <dl style="display: flex; flex-direction: column; gap: 12px; font-size: 0.875rem;">
          <div><dt style="color: #6b7280;">{t.city.population}:</dt><dd style="font-weight: 500;" class="text-gray-900 dark:text-white">{displayPopulation}</dd></div>
          <div><dt style="color: #6b7280;">{t.city.language}:</dt><dd style="font-weight: 500;" class="text-gray-900 dark:text-white">{displayLanguage}</dd></div>
          <div><dt style="color: #6b7280;">{t.city.currency}:</dt><dd style="font-weight: 500;" class="text-gray-900 dark:text-white">{displayCurrency}</dd></div>
          <div><dt style="color: #6b7280;">{t.city.timezone}:</dt><dd style="font-weight: 500;" class="text-gray-900 dark:text-white">{timezone}</dd></div>
          <div><dt style="color: #6b7280;">{t.city.bestSeason}:</dt><dd style="font-weight: 500;" class="text-gray-900 dark:text-white">{displayBestSeason}</dd></div>
        </dl>
      </aside>
    </div>
  </article>

  <script>
    function adjustContainerWidth() {
      const width = window.innerWidth;
      const maxWidth = width >= 1600 ? '1400px' : '1200px';
      const container = document.getElementById('city-detail-container');
      if (container instanceof HTMLElement) {
        container.style.maxWidth = maxWidth;
      }
    }
    adjustContainerWidth();
    window.addEventListener('resize', adjustContainerWidth);
  </script>
</BaseLayout>
