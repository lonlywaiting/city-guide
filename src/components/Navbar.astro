---
import { useTranslation, type Locale } from '../utils/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslation(locale);
const otherLocale = locale === 'zh' ? 'en' : 'zh';
const otherLocaleLabel = locale === 'zh' ? 'EN' : '中文';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<nav style="position: fixed; top: 0; width: 100%; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(8px); border-bottom: 1px solid #e5e7eb; z-index: 50;" class="dark:bg-gray-900/95 dark:border-gray-800">
  <div style="max-width: 1400px; margin: 0 auto; padding: 0 40px;">
    <div style="display: flex; justify-content: space-between; align-items: center; height: 72px;">
      <a href={`${baseUrl}/${locale}/`} style="font-size: 1.5rem; font-weight: 700; color: #111827; text-decoration: none; letter-spacing: -0.02em;" class="dark:text-white hover:opacity-80 transition-opacity">
        CityGuide
      </a>

      <div style="display: flex; align-items: center; gap: 32px;">
        <a href={`${baseUrl}/${locale}/`} style="font-size: 0.875rem; color: #4b5563; text-decoration: none; font-weight: 500;" class="dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors">{t.nav.home}</a>
        <a href={`${baseUrl}/${locale}/cities/`} style="font-size: 0.875rem; color: #4b5563; text-decoration: none; font-weight: 500;" class="dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors">{t.nav.explore}</a>
        <a href={Astro.url.pathname.replace(`/${locale}/`, `/${otherLocale}/`)}
           style="padding: 8px 16px; font-size: 0.875rem; border: 1px solid #d1d5db; border-radius: 6px; text-decoration: none; color: #374151; font-weight: 600;"
           class="dark:border-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
          {otherLocaleLabel}
        </a>
      </div>
    </div>
  </div>
</nav>
