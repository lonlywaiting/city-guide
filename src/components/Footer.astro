---
import { useTranslation, type Locale } from '../utils/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslation(locale);
---

<footer class="bg-gray-900 dark:bg-gray-950 text-white py-12 border-t border-gray-800">
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 32px; text-align: center;">
    <p class="text-sm">© 2026 CityGuide. {t.footer.rights}</p>
  </div>
</footer>
