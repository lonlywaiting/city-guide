---
interface Props {
  name: string;
  nameEn: string;
  country: string;
  countryEn?: string;
  image: string;
  id: string;
  locale: string;
}

const { name, nameEn, country, countryEn, image, id, locale } = Astro.props;
const displayName = locale === 'en' ? nameEn : name;
const displayCountry = locale === 'en' ? (countryEn || country) : country;
// 图片需要手动添加 BASE_URL，链接会自动处理
const imagePath = import.meta.env.BASE_URL.replace(/\/$/, '') + image;
---

<a href={`/${locale}/cities/${id}`}
   class="group block bg-white dark:bg-gray-800 rounded-lg overflow-hidden transition-all duration-200 hover:shadow-md border border-gray-200 dark:border-gray-700">
  <div class="aspect-[4/3] overflow-hidden bg-gray-100 dark:bg-gray-700" style="display: flex; align-items: center; justify-content: center;">
    <img src={imagePath} alt={displayName} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" width="400" height="300" style="object-position: center;" />
  </div>
  <div class="p-4">
    <h3 class="text-base font-medium text-gray-900 dark:text-white mb-1 line-clamp-1">{displayName}</h3>
    <p class="text-xs text-gray-500 dark:text-gray-400 mb-2 line-clamp-1">{locale === 'en' ? name : nameEn}</p>
    <div class="flex items-center gap-1 text-gray-400 dark:text-gray-500 text-xs">
      <svg class="w-3 h-3 flex-shrink-0" width="12" height="12" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
      </svg>
      <span class="line-clamp-1">{displayCountry}</span>
    </div>
  </div>
</a>
